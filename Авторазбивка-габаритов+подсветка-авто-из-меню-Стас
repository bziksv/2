/**
 * 📐 Разбивает габариты для ВСЕХ строк листа "Габариты"
 */
function processAllRows() {
  _processDimensionsMass(false);
}

/**
 * 🆕 Разбивает габариты ТОЛЬКО для пустых ячеек
 */
function processMissingOnly() {
  _processDimensionsMass(true);
}

/**
 * 🔧 Внутренняя функция массовой обработки габаритов
 */
function _processDimensionsMass(onlyMissing) {
  const CONFIG = {
    SHEET_NAME: "Габариты",
    HEADERS_ROW: 1,
    SPECIAL_VALUES: ["Стандартная упаковка", "Своя упаковка"],
    COURIER_KEYWORD: "курьерский пакет",
    DIM_REGEX: /(\d+(?:[.,]\d+)?)\s*[xх×*]\s*(\d+(?:[.,]\d+)?)(?:\s*[xх×*]\s*(\d+(?:[.,]\d+)?))?/i,
    HEADERS: {
      INPUT: "!тип упаковки",
      LENGTH: "!длина (см)",
      WIDTH: "!ширина (см)",
      BOX_HEIGHT: "высота (см) коробка",
      PACK_HEIGHT: "высота (см) пакет",
      WEIGHT: "!вес (кг)"
    }
  };

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CONFIG.SHEET_NAME);
  if (!sheet) { Logger.log(`❌ Лист "${CONFIG.SHEET_NAME}" не найден`); return; }

  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();
  if (lastRow < 2) { Logger.log("⚠️ Нет данных для обработки"); return; }

  const headers = sheet.getRange(CONFIG.HEADERS_ROW, 1, 1, lastCol).getValues()[0];
  const colMap = {};
  Object.entries(CONFIG.HEADERS).forEach(([key, name]) => {
    const target = name.toLowerCase().replace(/\s+/g, " ").trim();
    headers.forEach((h, i) => {
      const header = String(h).toLowerCase().replace(/\s+/g, " ").trim();
      if (header.includes(target)) colMap[key] = i + 1;
    });
  });

  if (!colMap.INPUT) { Logger.log("❌ Не найдена колонка '!тип упаковки'"); return; }
  if (!colMap.LENGTH || !colMap.WIDTH) { Logger.log("❌ Не найдены колонки для габаритов"); return; }

  const data = sheet.getRange(2, 1, lastRow - 1, lastCol).getValues();
  let processed = 0, updated = 0;

  for (let r = 0; r < data.length; r++) {
    const rowIdx = r + 2;
    const rawValue = String(data[r][colMap.INPUT - 1] || "").trim();
    if (!rawValue) continue;

    if (onlyMissing) {
      const hasLength = String(data[r][colMap.LENGTH - 1] || "").trim() !== "";
      const hasWidth = String(data[r][colMap.WIDTH - 1] || "").trim() !== "";
      if (hasLength && hasWidth) continue;
    }

    const isCourier = rawValue.toLowerCase().includes(CONFIG.COURIER_KEYWORD);
    const isSpecial = CONFIG.SPECIAL_VALUES.includes(rawValue);
    const match = rawValue.match(CONFIG.DIM_REGEX);

    if (match) {
      if (colMap.LENGTH) sheet.getRange(rowIdx, colMap.LENGTH).setValue(match[1]);
      if (colMap.WIDTH) sheet.getRange(rowIdx, colMap.WIDTH).setValue(match[2]);

      const thirdDim = match[3] || "";
      if (isCourier) {
        if (colMap.PACK_HEIGHT && thirdDim) sheet.getRange(rowIdx, colMap.PACK_HEIGHT).setValue(thirdDim);
        if (colMap.BOX_HEIGHT) sheet.getRange(rowIdx, colMap.BOX_HEIGHT).clearContent();
      } else {
        if (colMap.BOX_HEIGHT && thirdDim) sheet.getRange(rowIdx, colMap.BOX_HEIGHT).setValue(thirdDim);
        if (colMap.PACK_HEIGHT) sheet.getRange(rowIdx, colMap.PACK_HEIGHT).clearContent();
      }
      updated++;
    }
    processed++;
  }

  Logger.log(`✅ Обработано: ${processed} строк | Обновлено: ${updated} записей`);
}

